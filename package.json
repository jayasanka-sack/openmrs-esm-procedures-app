{
  "name": "@openmrs/esm-procedures-app",
  "version": "1.0.0",
  "license": "MPL-2.0",
  "description": "procedures-app frontend module for O3",
  "browser": "dist/openmrs-esm-procedures-app.js",
  "main": "src/index.ts",
  "source": true,
  "scripts": {
    "start": "openmrs develop",
    "build": "rspack --mode production",
    "build:development": "rspack --mode development",
    "analyze": "rspack --mode=production --env.analyze=true",
    "serve": "rspack serve --mode=development",
    "test": "cross-env TZ=UTC jest --config jest.config.js --verbose false --passWithNoTests --color",
    "test:watch": "cross-env TZ=UTC jest --watch --config jest.config.js --color",
    "coverage": "yarn test --coverage --passWithNoTests",
    "typescript": "tsc",
    "lint": "eslint src --ext ts,tsx",
    "extract-translations": "i18next 'src/**/*.component.tsx' 'src/**/*.extension.tsx' 'src/**/*.modal.tsx' 'src/index.ts' --config ./tools/i18next-parser.config.js",
    "prettier": "prettier --config prettier.config.js --write \"src/**/*.{ts,tsx,css,scss}\"",
    "postinstall": "husky install"
  },
  "keywords": [
    "openmrs",
    "microfrontends"
  ],
  "browserslist": [
    "extends browserslist-config-openmrs"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/openmrs/@openmrs/esm-procedures-app.git"
  },
  "bugs": {
    "url": "https://github.com/openmrs/@openmrs/esm-procedures-app/issues"
  },
  "homepage": "https://github.com/openmrs/@openmrs/esm-procedures-app#readme",
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "src"
  ],
  "dependencies": {
    "@carbon/react": "^1.83.0"
  },
  "peerDependencies": {
    "@carbon/react": "1.x",
    "@openmrs/esm-framework": "*",
    "dayjs": "1.x",
    "i18next": "21.x",
    "react": "18.x",
    "react-dom": "18.x",
    "react-hook-form": "^7.46.2",
    "react-i18next": "11.x",
    "react-is": "18.x",
    "react-router-dom": "6.x",
    "rxjs": "6.x",
    "sass": "1.x",
    "single-spa": "6.x",
    "swr": "2.x"
  },
  "devDependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@openmrs/esm-framework": "next",
    "@openmrs/esm-patient-common-lib": "^12.1.0",
    "@openmrs/rspack-config": "next",
    "@rspack/cli": "^1.7.10",
    "@swc/core": "^1.15.21",
    "@swc/jest": "^0.2.39",
    "@testing-library/jest-dom": "^6.4.5",
    "@testing-library/react": "^15.0.7",
    "@testing-library/user-event": "^14.5.2",
    "@types/identity-obj-proxy": "^3",
    "@types/jest": "^30.0.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@types/webpack-env": "^1.18.4",
    "@typescript-eslint/eslint-plugin": "^8.57.2",
    "@typescript-eslint/parser": "^8.57.2",
    "cross-env": "^7.0.3",
    "dayjs": "^1.11.13",
    "eslint": "^8.57.0",
    "eslint-plugin-import": "^2.31.0",
    "eslint-plugin-jest-dom": "^5.4.0",
    "eslint-plugin-playwright": "^0.16.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-testing-library": "^6.2.2",
    "husky": "^9.0.11",
    "i18next": "^21.0.0",
    "i18next-parser": "^9.0.1",
    "identity-obj-proxy": "^3.0.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "lint-staged": "^15.2.2",
    "openmrs": "next",
    "prettier": "^3.2.5",
    "react": "^18.1.0",
    "react-dom": "^18.1.0",
    "react-hook-form": "^7.72.0",
    "react-i18next": "^11.0.0",
    "react-is": "^18.3.1",
    "react-router-dom": "^6.3.0",
    "rxjs": "^6.5.3",
    "sass": "^1.33.0",
    "single-spa": "^6.0.0",
    "swr": "^2.0.0",
    "typescript": "^5.9.3",
    "zod": "^4.3.6"
  },
  "lint-staged": {
    "*.{ts,tsx}": "eslint --cache --fix --max-warnings 0",
    "*.{css,scss,ts,tsx}": "prettier --write --list-different"
  },
  "packageManager": "yarn@4.10.3"
}
